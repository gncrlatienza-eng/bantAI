# BantAI ML service configuration (copy to ai/.env). Prefix: BANTAI_AI_
BANTAI_AI_MODEL_DIR=models/xlm-roberta-smishing
BANTAI_AI_MAX_LENGTH=128

# Confidence-threshold routing (Sprint 2):
#   score >= 0.90 -> auto_block, 0.50-0.90 -> alert, < 0.50 -> inbox
BANTAI_AI_AUTO_BLOCK_THRESHOLD=0.90
BANTAI_AI_ALERT_THRESHOLD=0.50

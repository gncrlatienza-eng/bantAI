generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())

  phone     String   @unique
  email     String?  @unique

  firstName String?
  lastName  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SmsMessage[]
}

model OtpCode {
  id         String   @id @default(uuid())

  phone      String
  code       String

  expiresAt  DateTime
  verified   Boolean  @default(false)

  createdAt  DateTime @default(now())
}

model SmsMessage {
  id         String   @id @default(uuid())

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  sender     String
  body       String
  receivedAt DateTime @default(now())

  classification Classification?
  feature        MessageFeature?
  alerts         Alert[]
}

model MessageFeature {
  id             String     @id @default(uuid())

  messageId      String     @unique
  message        SmsMessage @relation(fields: [messageId], references: [id])

  normalizedBody String
  maskedBody     String

  createdAt      DateTime   @default(now())
}

model Classification {
  id        String   @id @default(uuid())

  messageId String   @unique
  message   SmsMessage @relation(fields: [messageId], references: [id])

  label     String   // Likely Smishing | Suspicious | Unknown
  score     Float

  createdAt DateTime @default(now())
}

model Alert {
  id        String   @id @default(uuid())

  messageId String
  message   SmsMessage @relation(fields: [messageId], references: [id])

  status    String   @default("Pending") // Pending | Blocked | Reported | Ignored

  createdAt DateTime @default(now())
}
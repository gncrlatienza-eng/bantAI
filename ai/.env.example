# BantAI ML service configuration (copy to ai/.env). Prefix: BANTAI_AI_
BANTAI_AI_MODEL_DIR=models/xlm-roberta-smishing
BANTAI_AI_MAX_LENGTH=128

# Confidence-threshold routing (Sprint 2). Model predicts Ham/Spam/Scam; these
# per-class thresholds decide the user bucket (below its bar -> Unknown/inbox):
#   Ham  >= SAFE_THRESHOLD  -> safe    (inbox)
#   Spam >= SPAM_THRESHOLD  -> spam    (dropdown)
#   Scam >= BLOCK_THRESHOLD -> blocked (dropdown)
BANTAI_AI_SAFE_THRESHOLD=0.50
BANTAI_AI_SPAM_THRESHOLD=0.60
BANTAI_AI_BLOCK_THRESHOLD=0.90
